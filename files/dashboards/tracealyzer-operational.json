{
  "title": "Tracealyzer — Operational",
  "uid": "tracealyzer-operational",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "tags": ["tracealyzer", "mdai", "operational"],
  "timezone": "",
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      },
      {
        "name": "namespace",
        "label": "Namespace",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(topology_spans_received_total, namespace)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "pod",
        "label": "Pod",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(topology_spans_received_total{namespace=~\"$namespace\"}, pod)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Overview",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Spans received",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 4 },
      "fieldConfig": { "defaults": { "unit": "ops", "color": { "mode": "thresholds" } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(topology_spans_received_total{namespace=~\"$namespace\",pod=~\"$pod\"}[$__rate_interval]))"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Traces finalized",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 6, "y": 1, "w": 6, "h": 4 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(topology_traces_finalized_total{namespace=~\"$namespace\",pod=~\"$pod\"}[$__rate_interval]))"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Compute p99",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 12, "y": 1, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 2 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(topology_compute_duration_seconds_bucket{namespace=~\"$namespace\",pod=~\"$pod\"}[$__rate_interval])))"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Emit failures",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 18, "y": 1, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.1 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(topology_emissions_failed_total{namespace=~\"$namespace\",pod=~\"$pod\"}[$__rate_interval]))"
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "Ingest & buffer",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Spans received — by pod",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (pod) (rate(topology_spans_received_total{namespace=~\"$namespace\",pod=~\"$pod\"}[$__rate_interval]))",
          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Malformed spans — by stage",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "stacking": { "mode": "normal" } } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (stage) (rate(topology_spans_malformed_total{namespace=~\"$namespace\",pod=~\"$pod\"}[$__rate_interval]))",
          "legendFormat": "{{stage}}"
        }
      ]
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Buffer rejections — by reason",
      "description": "overflow = Valkey maxmemory pressure; backend_error = any other write failure",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "stacking": { "mode": "normal" } } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (reason) (rate(topology_buffer_rejected_total{namespace=~\"$namespace\",pod=~\"$pod\"}[$__rate_interval]))",
          "legendFormat": "{{reason}}"
        }
      ]
    },
    {
      "id": 20,
      "type": "row",
      "title": "Sweep & finalize",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 22, "w": 24, "h": 1 }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Sweeps — by result",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 23, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "stacking": { "mode": "normal" } } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (result) (rate(topology_sweeps_total{namespace=~\"$namespace\",pod=~\"$pod\"}[$__rate_interval]))",
          "legendFormat": "{{result}}"
        }
      ]
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Traces finalized — by pod",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 12, "y": 23, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (pod) (rate(topology_traces_finalized_total{namespace=~\"$namespace\",pod=~\"$pod\"}[$__rate_interval]))",
          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "id": 23,
      "type": "timeseries",
      "title": "Finalization trigger — quiet vs max_ttl",
      "description": "If max_ttl dominates, the quiet-period config is too short for typical trace shapes.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 31, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "stacking": { "mode": "normal" } } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (trigger) (rate(topology_finalization_trigger_total{namespace=~\"$namespace\",pod=~\"$pod\"}[$__rate_interval]))",
          "legendFormat": "{{trigger}}"
        }
      ]
    },
    {
      "id": 24,
      "type": "timeseries",
      "title": "Drain errors — by pod",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 12, "y": 31, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (pod) (rate(topology_drain_errors_total{namespace=~\"$namespace\",pod=~\"$pod\"}[$__rate_interval]))",
          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "id": 30,
      "type": "row",
      "title": "Compute",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 39, "w": 24, "h": 1 }
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Compute duration — p50 / p95 / p99",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 40, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(topology_compute_duration_seconds_bucket{namespace=~\"$namespace\",pod=~\"$pod\"}[$__rate_interval])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(topology_compute_duration_seconds_bucket{namespace=~\"$namespace\",pod=~\"$pod\"}[$__rate_interval])))",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(topology_compute_duration_seconds_bucket{namespace=~\"$namespace\",pod=~\"$pod\"}[$__rate_interval])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 32,
      "type": "timeseries",
      "title": "Compute errors — by pod",
      "description": "Non-zero indicates a bug for a specific trace shape; ErrNoRoot is excluded (see compute_skipped).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 12, "y": 40, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (pod) (rate(topology_compute_errors_total{namespace=~\"$namespace\",pod=~\"$pod\"}[$__rate_interval]))",
          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "id": 33,
      "type": "timeseries",
      "title": "Compute skipped — by reason",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 48, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "stacking": { "mode": "normal" } } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (reason) (rate(topology_compute_skipped_total{namespace=~\"$namespace\",pod=~\"$pod\"}[$__rate_interval]))",
          "legendFormat": "{{reason}}"
        }
      ]
    },
    {
      "id": 34,
      "type": "timeseries",
      "title": "Orphan spans & bytes",
      "description": "Spans unreachable from any root, plus their apportioned OTLP byte share.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 12, "y": 48, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "ops" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "bytes" },
            "properties": [{ "id": "unit", "value": "Bps" }]
          }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(topology_orphan_spans_total{namespace=~\"$namespace\",pod=~\"$pod\"}[$__rate_interval]))",
          "legendFormat": "spans"
        },
        {
          "refId": "B",
          "expr": "sum(rate(topology_orphan_bytes_total{namespace=~\"$namespace\",pod=~\"$pod\"}[$__rate_interval]))",
          "legendFormat": "bytes"
        }
      ]
    },
    {
      "id": 40,
      "type": "row",
      "title": "Emit",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 56, "w": 24, "h": 1 }
    },
    {
      "id": 41,
      "type": "timeseries",
      "title": "Emission failures — by pod",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 57, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (pod) (rate(topology_emissions_failed_total{namespace=~\"$namespace\",pod=~\"$pod\"}[$__rate_interval]))",
          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "id": 42,
      "type": "timeseries",
      "title": "Emit success ratio",
      "description": "(finalized − failed) / finalized over the rate window. NaN when no traces finalized.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 12, "y": 57, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.95 },
              { "color": "green", "value": 0.999 }
            ]
          }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "refId": "A",
          "expr": "1 - (sum(rate(topology_emissions_failed_total{namespace=~\"$namespace\",pod=~\"$pod\"}[$__rate_interval])) / sum(rate(topology_traces_finalized_total{namespace=~\"$namespace\",pod=~\"$pod\"}[$__rate_interval])))",
          "legendFormat": "success ratio"
        }
      ]
    }
  ]
}
